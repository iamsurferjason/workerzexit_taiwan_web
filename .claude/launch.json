{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3010,
      "autoPort": true
    },
    {
      "name": "Prisma Studio",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "db:studio"],
      "port": 5555
    },
    {
      "name": "Docker Compose",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up"],
      "port": 8080
    }
  ]
}
