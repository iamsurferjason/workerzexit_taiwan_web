generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── 管理帳號 ──────────────────────────────────────────────

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(EDITOR)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum AdminRole {
  SUPER_ADMIN
  EDITOR
}

// ─── 商品分類 ──────────────────────────────────────────────

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  icon      String?
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ─── 商品 ──────────────────────────────────────────────────

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  price       Int
  externalUrl String
  images      ProductImage[]
  category    Category      @relation(fields: [categoryId], references: [id])
  categoryId  String
  tags        ProductTag[]
  isFeatured  Boolean       @default(false)
  isActive    Boolean       @default(true)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
}

enum ProductTag {
  NEW
  SOLD_OUT
  FEATURED
  SALE
}

// ─── 首頁 Banner ───────────────────────────────────────────

model Banner {
  id          String   @id @default(cuid())
  title       String?
  subtitle    String?
  imageUrl    String
  imageMobile String?
  ctaText     String?
  ctaUrl      String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── 廣告文宣 ──────────────────────────────────────────────

model Promotion {
  id          String    @id @default(cuid())
  title       String
  subtitle    String?
  imageUrl    String?
  imageMobile String?
  ctaText     String?
  ctaUrl      String?
  layout      PromotionLayout @default(FULL_WIDTH)
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum PromotionLayout {
  FULL_WIDTH
  TWO_COLUMN
}

// ─── 最新消息 ──────────────────────────────────────────────

model News {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  content     String
  coverImage  String?
  status      NewsStatus  @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum NewsStatus {
  DRAFT
  PUBLISHED
}

// ─── 網站設定 ──────────────────────────────────────────────

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
